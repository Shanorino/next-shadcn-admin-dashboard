# Local Environment Variables
# Copy this file to .env.local and fill in your actual values

# Amazon Seller API Configuration
# Get your API key from Amazon Seller Central: https://sellercentral.amazon.com/
AMAZON_SELLER_API_KEY=your_actual_amazon_seller_api_key_here

BETTER_AUTH_URL=http://localhost:3000/api/auth
DATABASE_URL=postgresql://postgres:password@localhost:5432/your_db
